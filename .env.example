# Variables d'environnement — GK SupportIT
# =========================================
# Copiez ce fichier en « .env » pour le développement local (netlify dev).
# En production, définissez ces variables dans Netlify :
#   Site settings > Environment variables.
#
# ⚠️ Ne committez JAMAIS le fichier .env réel (il est ignoré par Git).

# --- Espace admin (utilisé à partir de la Phase 3) ---

# Mot de passe de connexion à l'espace administrateur.
# Choisissez un mot de passe fort. Vérifié par la fonction de connexion.
ADMIN_PASSWORD=changez-moi

# Secret de signature des jetons de session (JWT).
# Générez une longue chaîne aléatoire, ex. :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacez-par-une-longue-chaine-aleatoire

# --- Netlify Blobs ---
# Aucune variable requise : le stockage Blobs est fourni automatiquement par
# le runtime Netlify (en local via `netlify dev` comme en production).

# --- Notifications push (Web Push / VAPID) ---
# Générez une paire de clés une seule fois :
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# La clé publique est exposée au navigateur ; la privée reste secrète.
VAPID_PUBLIC_KEY=cle-publique-vapid
VAPID_PRIVATE_KEY=cle-privee-vapid
# Contact du responsable (exigé par la spec Web Push).
VAPID_SUBJECT=mailto:vous@exemple.com
